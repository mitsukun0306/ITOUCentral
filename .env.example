# ITOUCentral 環境変数のサンプル。コピーして .env を作成してください。
# 本番(Render)では render.yaml とダッシュボードで設定するため、このファイルは主にローカル開発用です。

# PostgreSQL 接続文字列
#   ローカルで docker-compose を使う場合の例:
DATABASE_URL="postgresql://itoucentral:itoucentral@localhost:5432/itoucentral?schema=public"

# セッションJWTの署名鍵(十分に長いランダム文字列)
#   生成例: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-secret"

# 初期管理者(seed 実行時に使用。未設定なら開発用の既定値)
ADMIN_EMAIL="admin@itou.dev"
ADMIN_PASSWORD="admin1234"
ADMIN_NAME="管理者"
